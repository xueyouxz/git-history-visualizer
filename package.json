{
  "name": "git-history-visualizer",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "tsx src/server/main.ts",
    "build": "vite build && tsc --noEmit",
    "start": "NODE_ENV=production tsx src/server/main.ts",
    "test": "vitest run",
    "test:e2e": "vitest run test/import.e2e.test.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "react": "latest",
    "react-dom": "latest",
    "tsx": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
